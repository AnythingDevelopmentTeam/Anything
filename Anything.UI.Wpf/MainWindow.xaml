<Window x:Class="Anything.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anything"
        Height="500"
        Width="900"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1A1A1A">

    <Window.Resources>

        <!-- Цвета -->
        <SolidColorBrush x:Key="TitleBarBackground" Color="#202020"/>
        <SolidColorBrush x:Key="TitleButtonHover" Color="#333333"/>
        <SolidColorBrush x:Key="TitleButtonCloseHover" Color="#C42B1C"/>

    </Window.Resources>

<DockPanel>

    <!-- Кастомный заголовок -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource TitleBarBackground}"
            Height="32"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Anything"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="White"
                       FontSize="14"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Width="46" Height="32"
                        Background="Transparent"
                        MouseEnter="Minimize_Hover"
                        MouseLeave="TitleButton_Leave"
                        MouseLeftButtonUp="Minimize_Click">
                    <TextBlock Text="—"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="16"/>
                </Border>

                <Border Width="46" Height="32"
                        Background="Transparent"
                        MouseEnter="Maximize_Hover"
                        MouseLeave="TitleButton_Leave"
                        MouseLeftButtonUp="Maximize_Click">
                    <TextBlock Text="▢"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12"/>
                </Border>

                <Border Width="46" Height="32"
                        Background="Transparent"
                        MouseEnter="Close_Hover"
                        MouseLeave="TitleButton_Leave"
                        MouseLeftButtonUp="Close_Click">
                    <TextBlock Text="✕"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>

    <!-- 🔍 Поиск — ПЕРЕНЕСЁН СЮДА -->
    <TextBox DockPanel.Dock="Top"
             Margin="12"
             Background="#202020"
             Foreground="White"
             BorderBrush="#404040"
             Padding="8"
             FontSize="16"
             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"/>

    <!-- Список -->
    <ListView Margin="12"
              ItemsSource="{Binding Results}"
              MouseDoubleClick="ListView_DoubleClick"
              Background="#101010"
              Foreground="White">
        <ListView.View>
            <GridView>
                <GridViewColumn Header="Name" Width="250" DisplayMemberBinding="{Binding Name}"/>
                <GridViewColumn Header="Path" Width="600" DisplayMemberBinding="{Binding Path}"/>
            </GridView>
        </ListView.View>
    </ListView>

</DockPanel>


</Window>
